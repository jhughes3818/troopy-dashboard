generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model TelemetryReading {
  id         String   @id @default(cuid())
  deviceId   String
  voltage    Float?
  current    Float?
  soc        Float?
  power      Float?
  auxVoltage Float?
  ttgDays    Float?
  insideTempC  Float?
  outsideTempC Float?
  gpsValid    Boolean?
  gpsLatitude Float?
  gpsLongitude Float?
  gpsAltitudeM Float?
  gpsSpeedKmph Float?
  gpsCourseDeg Float?
  gpsSatellites Float?
  gpsHdop Float?
  gpsFixAgeMs Float?
  timestampMs BigInt
  receivedAt DateTime @default(now())

  @@index([receivedAt(sort: Desc)])
  @@index([deviceId, receivedAt(sort: Desc)])
  @@unique([deviceId, timestampMs])
}

model FuelLog {
  id         String   @id @default(cuid())
  filledAt   DateTime
  litres     Float
  isFull     Boolean  @default(false)
  distanceKm Float?
  pricePerL  Float?
  notes      String?
  createdAt  DateTime @default(now())

  @@index([filledAt(sort: Asc)])
}

model VehicleProfile {
  id            String  @id @default("vehicle")
  tankCapacityL Float
}
